# ============================================
# 科研试剂订单管理系统 — 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入实际值
# Vercel 部署时在 Dashboard → Settings → Environment Variables 中配置
# ============================================

# Supabase 项目 URL（必填，用于云端模式）
# 在 Supabase Dashboard → Settings → API → Project URL 中获取
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥（必填，用于云端模式）
# 在 Supabase Dashboard → Settings → API → anon/public key 中获取
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# 说明：
# - 不配置以上变量时，应用自动降级为 localStorage 本地模式
# - 配置后自动切换为 Supabase 云端模式，支持多人实时协作
# - VITE_ 前缀的变量会在构建时注入前端代码
# ============================================
